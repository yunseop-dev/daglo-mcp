{
  "name": "daglo-mcp",
  "version": "1.0.0",
  "description": "CLI for Daglo AI platform — speech-to-text and document management",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "daglo": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "dev": "tsc && chmod +x dist/cli.js && node dist/cli.js",
    "pipeline:youtube": "node scripts/youtube-auto-pipeline.mjs scripts/youtube-pipeline.config.json",
    "pipeline:youtube:bootstrap": "node scripts/bootstrap-youtube-pipeline-config.mjs",
    "pipeline:youtube:install-launchd": "bash scripts/install-youtube-pipeline-launchd.sh",
    "pipeline:youtube:preflight": "node scripts/nas-preflight-check.mjs scripts/youtube-pipeline.config.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:all-tools": "node scripts/test-all-tools.js",
    "test:debug": "node scripts/debug-script.js",
    "test:board-detail": "node scripts/test-board-detail.js"
  },
  "keywords": [
    "daglo",
    "cli",
    "ai",
    "speech-to-text"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "pino": "^10.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitest/ui": "^4.0.16",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  }
}
